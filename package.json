{
  "name": "axecoder",
  "version": "0.6.0",
  "main": "dist-electron/main/index.js",
  "description": "代码编写桌面 IDE — Electron + Vue 3 + Monaco",
  "author": "崔老六 <cuiyunfeng@huazhengit.com>",
  "license": "MIT",
  "private": true,
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "npm run codegraph:build && node scripts/patch-electron-plist.mjs && vite",
    "icon:gen": "node scripts/gen-icon.mjs",
    "build": "npm run codegraph:build && vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "codegraph:build": "tsc -p electron/main/codegraph/tsconfig.json && node electron/main/codegraph/copy-assets.mjs",
    "postinstall": "npx @electron/rebuild -w better-sqlite3 node-pty -f && node scripts/fix-node-pty-perms.mjs",
    "verify:codegraph": "npm run codegraph:build && ELECTRON_RUN_AS_NODE=1 electron scripts/probe-codegraph-electron.cjs && node scripts/probe-codegraph-bundle.cjs && node scripts/probe-codegraph-packaged.cjs"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/markdown-it": "^14.1.2",
    "@types/picomatch": "^4.0.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^3.0.5",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.6"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vscode/ripgrep": "^1.15.11",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^4.0.3",
    "diff": "^7.0.0",
    "electron-store": "^10.0.0",
    "html-to-docx": "^1.8.0",
    "ignore": "^7.0.5",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.2.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "picomatch": "^4.0.3",
    "playwright": "^1.60.0",
    "tree-sitter-wasms": "^0.1.11",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-types": "^3.17.5",
    "web-tree-sitter": "^0.25.3"
  },
  "build": {
    "appId": "com.axecoder.app",
    "productName": "AxeCoder",
    "icon": "build/icon.png",
    "directories": {
      "output": "release/${version}"
    },
    "extraResources": [
      {
        "from": "electron/main/codegraph/dist",
        "to": "codegraph",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/node-pty/**"
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!release",
      "!release/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "zip"
      ],
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    }
  }
}
